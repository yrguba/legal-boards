# Frontend Vite — production on-prem (скопировать в /opt/legal-boards/shared/build.env)
# Используется при install.sh / update.sh перед pnpm build

# Same-origin: API через nginx /api
VITE_API_URL=/api

# WebSocket — обычно не нужен при same-origin (см. src/app/utils/wsUrl.ts)
# VITE_WS_URL=

# Legal Forms microfrontend
VITE_FORMS_MICROAPP_ENABLED=false
# VITE_FORMS_API_ORIGIN=https://legal-forms.customer.ru
# VITE_FORMS_DOCSTREAM_ORIGIN=https://legal-forms.customer.ru/docstream
# VITE_FORMS_MICRO_APP_ENTRY=/docstream/forms-app/
# VITE_FORMS_DEFAULT_PATH=/forms/...
