# Backend — production on-prem (скопировать в /opt/legal-boards/shared/backend.env)
# cp deploy/on-prem/shared/backend.env.example /opt/legal-boards/shared/backend.env

DATABASE_URL="postgresql://legalboards:CHANGE_ME@localhost:5432/legalboards?schema=public"
JWT_SECRET="CHANGE_ME-long-random-secret"
PORT=5004
NODE_ENV=production
UPLOAD_DIR=/opt/legal-boards/shared/uploads

# Публичный URL фронтенда (ссылки в письмах)
FRONTEND_URL=https://boards.customer.ru

# Регистрация и приглашения
REGISTRATION_ENABLED=false
WORKSPACE_INVITE_EMAIL=false

# Email (Resend) — опционально
# RESEND_API_KEY=
# RESEND_FROM="Legal Boards <noreply@customer.ru>"

# Модули — включить по договорённости
LEXPRO_CLIENTS_ENABLED=true
DOCUMENTS_ENABLED=true
KNOWLEDGE_ENABLED=true
CHAT_ENABLED=true
CALENDAR_ENABLED=true
CONFERENCES_ENABLED=false
PUSH_ENABLED=false
FEEDBACK_ENABLED=true

# Groq (ассистент в чате) — опционально
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Jitsi (если CONFERENCES_ENABLED=true)
# JITSI_DOMAIN=meet.customer.ru
