generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TaskColumnApproval {
  id               String   @id @default(cuid())
  taskId           String
  ruleId           String
  columnId         String
  ruleName         String   @default("")
  approvedByUserId String
  status           String   @default("approved")
  reason           String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  approver User @relation("TaskColumnApprovalApprover", fields: [approvedByUserId], references: [id], onDelete: Cascade)

  @@unique([taskId, ruleId])
  @@index([taskId])
  @@index([columnId])
  @@index([approvedByUserId])
  @@index([status])
}

model TaskColumnActionCompletion {
  id               String   @id @default(cuid())
  taskId           String
  ruleId           String
  columnId         String
  ruleName         String   @default("")
  actionKind       String
  payload          Json     @default("{}")
  completedByUserId String
  createdAt        DateTime @default(now())

  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completer User @relation("TaskColumnActionCompleter", fields: [completedByUserId], references: [id], onDelete: Cascade)

  @@unique([taskId, ruleId])
  @@index([taskId])
  @@index([columnId])
  @@index([completedByUserId])
}

/// Append-only аудит операций по задачам (отчётность и timeline)
model ActivityLog {
  id               String   @id @default(cuid())
  workspaceId      String
  boardId          String
  taskId           String
  eventType        String
  actorUserId      String?
  actorLexClientId String?
  occurredAt       DateTime @default(now())
  payload          Json     @default("{}")
  snapshot         Json?
  source           String   @default("api")

  task      Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actorUser User? @relation("ActivityLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([taskId, occurredAt])
  @@index([boardId, eventType, occurredAt])
  @@index([workspaceId, occurredAt])
  @@index([actorUserId])
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String
  password     String
  role         String         @default("member")
  avatar       String?
  departmentId String?
  /// Подтверждён ли email (самостоятельная регистрация)
  emailVerified Boolean       @default(false)
  emailVerificationToken String? @unique
  emailVerificationExpiresAt DateTime?
  /// Требовать смену пароля при следующем входе (временный пароль от администратора)
  mustChangePassword Boolean  @default(false)
  /// Одноразовая ссылка-приглашение для активации / сброса пароля
  passwordInviteToken String? @unique
  passwordInviteExpiresAt DateTime?
  /// Самостоятельное восстановление пароля (REGISTRATION_ENABLED)
  passwordResetToken String? @unique
  passwordResetExpiresAt DateTime?
  /// Значения настраиваемых полей профиля (ключ → значение)
  profileFields Json          @default("{}")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  department      Department?       @relation(fields: [departmentId], references: [id])
  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  workspaces      WorkspaceUser[]
  groups          UserGroup[]
  createdTasks    Task[]            @relation("TaskCreator")
  assignedTasks   Task[]            @relation("TaskAssignee")
  comments                 Comment[]
  chatMessages             ChatMessage[]
  taskClientInteractions   TaskClientInteraction[]
  taskAttachments         TaskAttachment[]
  commentAttachments      CommentAttachment[]
  workspaceChatMessageAttachments WorkspaceChatMessageAttachment[]
  documents                Document[]
  workspaceChatMessages    WorkspaceChatMessage[]
  notifications            Notification[]
  calendarEventsCreated    CalendarEvent[]           @relation("CalendarEventCreator")
  calendarEventAttendees   CalendarEventAttendee[]
  knowledgeArticlesCreated KnowledgeArticle[]
  taskColumnApprovals      TaskColumnApproval[] @relation("TaskColumnApprovalApprover")
  taskColumnActionCompletions TaskColumnActionCompletion[] @relation("TaskColumnActionCompleter")
  taskBoardTransitions        TaskBoardTransition[]        @relation("TaskBoardTransitionActor")
  activityLogs             ActivityLog[] @relation("ActivityLogActor")
  ledGroups                Group[] @relation("GroupLeader")
  createdConferences       Conference[] @relation("ConferenceCreator")
  workspaceInvitesReceived WorkspaceInvite[] @relation("WorkspaceInvitee")
  workspaceInvitesSent     WorkspaceInvite[] @relation("WorkspaceInviter")
  pushDevices              PushDevice[]
  notificationPreferences  NotificationPreference[]
  presences                UserPresence[]
  absences                 UserAbsence[] @relation("UserAbsences")
  absencesSubstituting     UserAbsence[] @relation("UserAbsenceSubstitute")
  feedbackTickets          FeedbackTicket[]

  @@index([email])
  @@index([departmentId])
}

/// Статус присутствия сотрудника в рамках пространства
model UserPresence {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  status      String    @default("available")
  customText  String?
  expiresAt   DateTime?
  updatedAt   DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@index([userId])
}

/// Период отсутствия (отпуск, больничный и т.д.)
model UserAbsence {
  id               String   @id @default(cuid())
  userId           String
  workspaceId      String
  kind             String   @default("vacation")
  startDate        DateTime @db.Date
  endDate          DateTime @db.Date
  note             String?
  substituteUserId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user       User       @relation("UserAbsences", fields: [userId], references: [id], onDelete: Cascade)
  substitute User?      @relation("UserAbsenceSubstitute", fields: [substituteUserId], references: [id], onDelete: SetNull)
  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, workspaceId])
  @@index([workspaceId, startDate, endDate])
}

/// Обратная связь: ошибки, предложения, вопросы
model FeedbackTicket {
  id          String   @id @default(cuid())
  category    String
  subject     String
  description String   @db.Text
  status      String   @default("new")
  userId      String
  workspaceId String?
  pageUrl     String?
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  attachments FeedbackAttachment[]

  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([status, createdAt])
}

model FeedbackAttachment {
  id        String   @id @default(cuid())
  ticketId  String
  name      String
  type      String
  size      Int
  path      String
  createdAt DateTime @default(now())

  ticket FeedbackTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

/// Пользователи приложения LEXPRO (отдельно от User / Legal Boards)
model LexClientUser {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  clientKind  String
  companyName String?
  /// Контакт после создания запроса (LEXPRO)
  phone         String?
  contactNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaces          LexClientWorkspace[]
  tasks                 Task[]               @relation("LexTaskCreator")
  chatMessages          ChatMessage[]
  attachmentsUploaded   TaskAttachment[]
}

/// Связь клиента LEXPRO с пространством — при первой задаче на доске этого workspace
model LexClientWorkspace {
  id          String   @id @default(cuid())
  lexClientId String
  workspaceId String
  createdAt   DateTime @default(now())

  lexClient   LexClientUser @relation(fields: [lexClientId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([lexClientId, workspaceId])
  @@index([workspaceId])
  @@index([lexClientId])
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  users       WorkspaceUser[]
  departments Department[]
  groups      Group[]
  employeeProfileFields EmployeeProfileField[]
  boards      Board[]
  documents   Document[]
  chatChannels WorkspaceChatChannel[]
  calendarEvents CalendarEvent[]
  conferences    Conference[]
  knowledgeArticles KnowledgeArticle[]
  lexClients LexClientWorkspace[]
  invites           WorkspaceInvite[]
  userPresences     UserPresence[]
  userAbsences      UserAbsence[]
  feedbackTickets   FeedbackTicket[]

  @@index([ownerId])
}

model WorkspaceUser {
  id            String   @id @default(cuid())
  workspaceId   String
  userId        String
  role          String   @default("member")
  departmentId  String?
  profileFields Json     @default("{}")
  joinedAt      DateTime @default(now())

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@index([departmentId])
}

model WorkspaceInvite {
  id           String    @id @default(cuid())
  workspaceId  String
  userId       String
  invitedById  String
  role         String    @default("member")
  departmentId String?
  groupIds     Json      @default("[]")
  status       String    @default("pending")
  token        String    @unique
  expiresAt    DateTime
  respondedAt  DateTime?
  createdAt    DateTime  @default(now())

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user       User        @relation("WorkspaceInvitee", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy  User        @relation("WorkspaceInviter", fields: [invitedById], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([userId])
  @@index([userId, status])
  @@index([status])
}

model Department {
  id          String   @id @default(cuid())
  name        String
  description String?
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  users     User[]
  groups    Group[]
  chatChannels WorkspaceChatChannel[]
  workspaceMembers WorkspaceUser[]
  workspaceInvites WorkspaceInvite[]

  @@index([workspaceId])
}

model Group {
  id           String      @id @default(cuid())
  name         String
  description  String?
  workspaceId  String
  /// Направление / продукт внутри отдела
  departmentId String
  /// Руководитель направления
  leaderId     String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  department Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  leader     User?       @relation("GroupLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  users      UserGroup[]
  chatChannels WorkspaceChatChannel[]

  @@index([workspaceId])
  @@index([departmentId])
  @@index([leaderId])
}

/// Настраиваемая схема полей карточки сотрудника (одна на workspace)
model EmployeeProfileField {
  id          String   @id @default(cuid())
  workspaceId String
  key         String
  name        String
  type        String
  required    Boolean  @default(false)
  filterable  Boolean  @default(true)
  /// Конфиденциальное поле: видно только сотруднику, руководителю направления и администратору
  confidential Boolean @default(false)
  /// Маска ввода: passport | departmentCode | snils | phone | inn | digits | money
  mask        String?
  options     Json?
  position    Int
  section     String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@index([position])
}

model UserGroup {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  joinedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
}

model Board {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  workspaceId String
  viewMode    String   @default("kanban")
  /// standard — обычная доска; aggregated — сводная над выбранными досками
  kind        String   @default("standard")
  visibility  Json     @default("{}")
  attachmentsEnabled Boolean @default(true)
  /// Расширенные настройки доски (JSON): авто-назначение, учёт времени по статусам, iframe-сервисы
  advancedSettings Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace  Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  columns    BoardColumn[]
  taskFields TaskField[]
  taskTypes  TaskType[]
  tasks      Task[]
  taskPlacements TaskBoardPlacement[]
  codeAliases BoardCodeAlias[]
  aggregatedSources AggregatedBoardSource[] @relation("AggregatedBoard")
  aggregatedIn      AggregatedBoardSource[] @relation("SourceBoard")

  @@index([workspaceId])
  @@index([kind])
}

/// Исходные доски, входящие в сводную
model AggregatedBoardSource {
  id                String @id @default(cuid())
  aggregatedBoardId String
  sourceBoardId     String
  position          Int

  aggregatedBoard Board @relation("AggregatedBoard", fields: [aggregatedBoardId], references: [id], onDelete: Cascade)
  sourceBoard     Board @relation("SourceBoard", fields: [sourceBoardId], references: [id], onDelete: Cascade)

  @@unique([aggregatedBoardId, sourceBoardId])
  @@index([aggregatedBoardId])
  @@index([sourceBoardId])
}

/// Старые коды доски для redirect URL после смены code
model BoardCodeAlias {
  id        String   @id @default(cuid())
  boardId   String
  code      String   @unique
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
}

model BoardColumn {
  id          String   @id @default(cuid())
  boardId     String
  name        String
  description String?
  position    Int
  autoAssign  Json?
  visibility  Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]
  taskPlacements TaskBoardPlacement[]

  @@index([boardId])
  @@index([position])
}

model TaskField {
  id       String  @id @default(cuid())
  boardId  String
  name     String
  type     String
  required Boolean @default(false)
  options  Json?
  position Int

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
  @@index([position])
}

model TaskType {
  id      String @id @default(cuid())
  boardId String
  name    String
  color   String
  icon    String?

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]
  taskPlacements TaskBoardPlacement[]

  @@index([boardId])
}

model Task {
  id           String   @id @default(cuid())
  /// Сквозной номер задачи на доске (1, 2, 3…); публичный ключ: {board.code}-{number}
  number       Int
  boardId      String
  columnId     String
  typeId       String
  title        String
  description  String?
  assigneeId   String?
  /// Автор со стороны Legal Boards (null — задачу создал клиент LEXPRO)
  createdBy    String?
  /// Автор–клиент LEXPRO (null — задачу создал сотрудник)
  lexCreatorId String?
  customFields Json     @default("{}")
  /// Приоритет (ключ): trivial | low | medium | high | critical
  priority     String   @default("medium")
  /// Порядок внутри колонки (0 — сверху)
  position     Int      @default(0)
  /// Накопленное время работы по правилам доски (секунды)
  trackedTimeSeconds       Int       @default(0)
  /// Начало текущего отрезка учёта (когда задача в «считающейся» колонке цикла)
  timeTrackingActiveSince  DateTime?
  /// Цикл «от колонки старт до стоп» открыт (посещена стартовая колонка)
  timeTrackingCycleOpen    Boolean   @default(false)
  /// Заключение исполнителя для клиента (LEXPRO и др.)
  conclusionText           String?   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  board        Board           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column       BoardColumn     @relation(fields: [columnId], references: [id])
  type         TaskType        @relation(fields: [typeId], references: [id])
  creator      User?           @relation("TaskCreator", fields: [createdBy], references: [id])
  lexCreator   LexClientUser?  @relation("LexTaskCreator", fields: [lexCreatorId], references: [id])
  assignee     User?           @relation("TaskAssignee", fields: [assigneeId], references: [id])
  comments             Comment[]
  chatMessages         ChatMessage[]
  clientInteractions   TaskClientInteraction[]
  taskAttachments      TaskAttachment[]
  statusTimelineEvents TaskStatusEvent[]
  columnApprovals      TaskColumnApproval[]
  columnActionCompletions TaskColumnActionCompletion[]
  activityLogs         ActivityLog[]
  boardPlacements      TaskBoardPlacement[]
  boardTransitions     TaskBoardTransition[]

  @@unique([boardId, number])
  @@index([boardId])
  @@index([columnId])
  @@index([columnId, position])
  @@index([typeId])
  @@index([assigneeId])
  @@index([createdBy])
  @@index([lexCreatorId])
}

/// История смены колонки/типа задачи (для LEXPRO и GET /tasks/:id/status-history), не зависит от получателей уведомлений
model TaskStatusEvent {
  id        String   @id @default(cuid())
  taskId    String
  kind      String
  message   String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([taskId, createdAt])
}

/// Размещение задачи на доске (свой статус/колонка на каждой доске)
model TaskBoardPlacement {
  id        String   @id @default(cuid())
  taskId    String
  boardId   String
  columnId  String
  typeId    String
  position  Int      @default(0)
  isPrimary Boolean  @default(false)
  linkedFromBoardId  String?
  linkedFromColumnId String?
  linkedByRuleId     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  board  Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column BoardColumn @relation(fields: [columnId], references: [id])
  type   TaskType    @relation(fields: [typeId], references: [id])

  @@unique([taskId, boardId])
  @@index([boardId, columnId])
  @@index([boardId, columnId, position])
  @@index([taskId])
}

/// История перемещений задачи между досками и колонками
model TaskBoardTransition {
  id             String   @id @default(cuid())
  taskId         String
  workspaceId    String
  eventKind      String
  boardId        String
  columnId       String?
  fromColumnId   String?
  toColumnId     String?
  targetBoardId  String?
  targetColumnId String?
  ruleId         String?
  ruleName       String?
  actorUserId    String?
  source         String   @default("api")
  payload        Json     @default("{}")
  occurredAt     DateTime @default(now())

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User? @relation("TaskBoardTransitionActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([taskId, occurredAt])
  @@index([workspaceId, occurredAt])
  @@index([boardId, occurredAt])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task        Task                @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments CommentAttachment[]

  @@index([taskId])
  @@index([userId])
}

model CommentAttachment {
  id         String   @id @default(cuid())
  commentId  String
  name       String
  type       String
  size       Int
  path       String
  uploadedBy String
  createdAt  DateTime @default(now())

  comment  Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  uploader User    @relation(fields: [uploadedBy], references: [id])

  @@index([commentId])
  @@index([uploadedBy])
}

model ChatMessage {
  id              String   @id @default(cuid())
  taskId          String
  type            String
  content         String
  sender          String
  userId          String?
  lexClientUserId String?
  createdAt       DateTime @default(now())

  task          Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lexClientUser LexClientUser? @relation(fields: [lexClientUserId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([lexClientUserId])
}

model TaskClientInteraction {
  id         String   @id @default(cuid())
  taskId     String
  userId     String
  kind       String
  title      String
  details    String?
  occurredAt DateTime
  createdAt  DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([occurredAt])
}

// Task-scoped file rows (separate from workspace Document)
model TaskAttachment {
  id                    String   @id @default(cuid())
  taskId                String
  name                  String
  type                  String
  size                  Int
  path                  String
  uploadedBy            String?
  uploadedByLexClientId String?
  /// general — обычные вложения; conclusion — файл к заключению исполнителя (видно во вкладке «Заключение» LEXPRO)
  purpose               String    @default("general")
  createdAt             DateTime @default(now())

  task          Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader      User?          @relation(fields: [uploadedBy], references: [id])
  lexUploader   LexClientUser? @relation(fields: [uploadedByLexClientId], references: [id])

  @@index([taskId])
  @@index([uploadedBy])
  @@index([uploadedByLexClientId])
  @@index([taskId, purpose])
}

model Document {
  id          String   @id @default(cuid())
  name        String
  type        String
  size        Int
  path        String
  uploadedBy  String
  workspaceId String
  visibility  Json     @default("{}")
  uploadedAt  DateTime @default(now())

  uploader  User      @relation(fields: [uploadedBy], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([uploadedBy])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  userId    String
  relatedId String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model PushDevice {
  id         String   @id @default(cuid())
  userId     String
  platform   String
  provider   String
  token      String   @unique
  deviceId   String?
  appVersion String?
  isActive   Boolean  @default(true)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, platform])
  @@index([isActive])
}

/// Настройки уведомлений пользователя (in-app + push, общие категории)
model NotificationPreference {
  userId    String
  key       String
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, key])
  @@index([userId])
}

// Чаты пространства / отдела / группы (отдельно от чата внутри задачи)
model WorkspaceChatChannel {
  id           String   @id @default(cuid())
  channelKey   String   @unique
  workspaceId  String
  scope        String
  departmentId String?
  groupId      String?
  /// Участники личного чата (JSON-массив userId, отсортирован)
  directUserIds Json     @default("[]")
  title        String
  createdAt    DateTime @default(now())

  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  group      Group?      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  messages   WorkspaceChatMessage[]

  @@index([workspaceId])
  @@index([workspaceId, scope])
  @@index([departmentId])
  @@index([groupId])
}

model WorkspaceChatMessage {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  content   String
  createdAt DateTime @default(now())

  channel     WorkspaceChatChannel              @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user        User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments WorkspaceChatMessageAttachment[]

  @@index([channelId, createdAt])
  @@index([userId])
}

model WorkspaceChatMessageAttachment {
  id         String   @id @default(cuid())
  messageId  String
  name       String
  type       String
  size       Int
  path       String
  uploadedBy String
  createdAt  DateTime @default(now())

  message  WorkspaceChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploader User                 @relation(fields: [uploadedBy], references: [id])

  @@index([messageId])
  @@index([uploadedBy])
}

model CalendarEvent {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("CalendarEventCreator", fields: [createdById], references: [id], onDelete: Cascade)
  attendees CalendarEventAttendee[]

  @@index([workspaceId])
  @@index([workspaceId, startAt])
}

model CalendarEventAttendee {
  id      String @id @default(cuid())
  eventId String
  userId  String

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
}

/// Видеоконференция (Jitsi)
model Conference {
  id            String   @id @default(cuid())
  workspaceId   String
  title         String
  /// Имя комнаты Jitsi (уникальное)
  roomName      String   @unique
  /// Токен для публичной ссылки приглашения
  shareToken    String   @unique
  mode          String   @default("instant")
  status        String   @default("active")
  startAt       DateTime @default(now())
  endAt         DateTime?
  createdById   String
  calendarEventId String?
  allowGuests   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("ConferenceCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([createdById])
}

/// Страница или раздел в базе знаний рабочего пространства (дерево: parent → children).
model KnowledgeArticle {
  id          String @id @default(cuid())
  workspaceId String
  parentId    String?
  title       String
  body        String @default("") @db.Text
  position    Int    @default(0)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent    KnowledgeArticle? @relation("KnowledgeTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  KnowledgeArticle[] @relation("KnowledgeTree")
  creator   User                  @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([parentId])
}
