generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String
  password     String
  role         String         @default("member")
  avatar       String?
  departmentId String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  department      Department?       @relation(fields: [departmentId], references: [id])
  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  workspaces      WorkspaceUser[]
  groups          UserGroup[]
  createdTasks    Task[]            @relation("TaskCreator")
  assignedTasks   Task[]            @relation("TaskAssignee")
  comments                 Comment[]
  chatMessages             ChatMessage[]
  taskClientInteractions   TaskClientInteraction[]
  taskAttachments         TaskAttachment[]
  documents                Document[]
  workspaceChatMessages    WorkspaceChatMessage[]
  notifications            Notification[]
  calendarEventsCreated    CalendarEvent[]           @relation("CalendarEventCreator")
  calendarEventAttendees   CalendarEventAttendee[]
  knowledgeArticlesCreated KnowledgeArticle[]

  @@index([email])
  @@index([departmentId])
}

/// Пользователи приложения LEXPRO (отдельно от User / Legal Boards)
model LexClientUser {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  clientKind  String
  companyName String?
  /// Контакт после создания запроса (LEXPRO)
  phone         String?
  contactNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaces          LexClientWorkspace[]
  tasks                 Task[]               @relation("LexTaskCreator")
  chatMessages          ChatMessage[]
  attachmentsUploaded   TaskAttachment[]
}

/// Связь клиента LEXPRO с пространством — при первой задаче на доске этого workspace
model LexClientWorkspace {
  id          String   @id @default(cuid())
  lexClientId String
  workspaceId String
  createdAt   DateTime @default(now())

  lexClient   LexClientUser @relation(fields: [lexClientId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([lexClientId, workspaceId])
  @@index([workspaceId])
  @@index([lexClientId])
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  users       WorkspaceUser[]
  departments Department[]
  groups      Group[]
  boards      Board[]
  documents   Document[]
  chatChannels WorkspaceChatChannel[]
  calendarEvents CalendarEvent[]
  knowledgeArticles KnowledgeArticle[]
  lexClients LexClientWorkspace[]

  @@index([ownerId])
}

model WorkspaceUser {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  joinedAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Department {
  id          String   @id @default(cuid())
  name        String
  description String?
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  users     User[]
  chatChannels WorkspaceChatChannel[]

  @@index([workspaceId])
}

model Group {
  id          String      @id @default(cuid())
  name        String
  description String?
  workspaceId String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  users     UserGroup[]
  chatChannels WorkspaceChatChannel[]

  @@index([workspaceId])
}

model UserGroup {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  joinedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
}

model Board {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  workspaceId String
  viewMode    String   @default("kanban")
  visibility  Json     @default("{}")
  attachmentsEnabled Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace  Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  columns    BoardColumn[]
  taskFields TaskField[]
  taskTypes  TaskType[]
  tasks      Task[]

  @@index([workspaceId])
}

model BoardColumn {
  id          String   @id @default(cuid())
  boardId     String
  name        String
  description String?
  position    Int
  autoAssign  Json?
  visibility  Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([boardId])
  @@index([position])
}

model TaskField {
  id       String  @id @default(cuid())
  boardId  String
  name     String
  type     String
  required Boolean @default(false)
  options  Json?
  position Int

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
  @@index([position])
}

model TaskType {
  id      String @id @default(cuid())
  boardId String
  name    String
  color   String
  icon    String?

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([boardId])
}

model Task {
  id           String   @id @default(cuid())
  boardId      String
  columnId     String
  typeId       String
  title        String
  description  String?
  assigneeId   String?
  /// Автор со стороны Legal Boards (null — задачу создал клиент LEXPRO)
  createdBy    String?
  /// Автор–клиент LEXPRO (null — задачу создал сотрудник)
  lexCreatorId String?
  customFields Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  board        Board           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column       BoardColumn     @relation(fields: [columnId], references: [id])
  type         TaskType        @relation(fields: [typeId], references: [id])
  creator      User?           @relation("TaskCreator", fields: [createdBy], references: [id])
  lexCreator   LexClientUser?  @relation("LexTaskCreator", fields: [lexCreatorId], references: [id])
  assignee     User?           @relation("TaskAssignee", fields: [assigneeId], references: [id])
  comments             Comment[]
  chatMessages         ChatMessage[]
  clientInteractions   TaskClientInteraction[]
  taskAttachments      TaskAttachment[]
  statusTimelineEvents TaskStatusEvent[]

  @@index([boardId])
  @@index([columnId])
  @@index([typeId])
  @@index([assigneeId])
  @@index([createdBy])
  @@index([lexCreatorId])
}

/// История смены колонки/типа задачи (для LEXPRO и GET /tasks/:id/status-history), не зависит от получателей уведомлений
model TaskStatusEvent {
  id        String   @id @default(cuid())
  taskId    String
  kind      String
  message   String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([taskId, createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

model ChatMessage {
  id              String   @id @default(cuid())
  taskId          String
  type            String
  content         String
  sender          String
  userId          String?
  lexClientUserId String?
  createdAt       DateTime @default(now())

  task          Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lexClientUser LexClientUser? @relation(fields: [lexClientUserId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([lexClientUserId])
}

model TaskClientInteraction {
  id         String   @id @default(cuid())
  taskId     String
  userId     String
  kind       String
  title      String
  details    String?
  occurredAt DateTime
  createdAt  DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([occurredAt])
}

// Task-scoped file rows (separate from workspace Document)
model TaskAttachment {
  id                    String   @id @default(cuid())
  taskId                String
  name                  String
  type                  String
  size                  Int
  path                  String
  uploadedBy            String?
  uploadedByLexClientId String?
  createdAt             DateTime @default(now())

  task          Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader      User?          @relation(fields: [uploadedBy], references: [id])
  lexUploader   LexClientUser? @relation(fields: [uploadedByLexClientId], references: [id])

  @@index([taskId])
  @@index([uploadedBy])
  @@index([uploadedByLexClientId])
}

model Document {
  id          String   @id @default(cuid())
  name        String
  type        String
  size        Int
  path        String
  uploadedBy  String
  workspaceId String
  visibility  Json     @default("{}")
  uploadedAt  DateTime @default(now())

  uploader  User      @relation(fields: [uploadedBy], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([uploadedBy])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  userId    String
  relatedId String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// Чаты пространства / отдела / группы (отдельно от чата внутри задачи)
model WorkspaceChatChannel {
  id           String   @id @default(cuid())
  channelKey   String   @unique
  workspaceId  String
  scope        String
  departmentId String?
  groupId      String?
  title        String
  createdAt    DateTime @default(now())

  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  group      Group?      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  messages   WorkspaceChatMessage[]

  @@index([workspaceId])
  @@index([departmentId])
  @@index([groupId])
}

model WorkspaceChatMessage {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  content   String
  createdAt DateTime @default(now())

  channel WorkspaceChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
  @@index([userId])
}

model CalendarEvent {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("CalendarEventCreator", fields: [createdById], references: [id], onDelete: Cascade)
  attendees CalendarEventAttendee[]

  @@index([workspaceId])
  @@index([workspaceId, startAt])
}

model CalendarEventAttendee {
  id      String @id @default(cuid())
  eventId String
  userId  String

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
}

/// Страница или раздел в базе знаний рабочего пространства (дерево: parent → children).
model KnowledgeArticle {
  id          String @id @default(cuid())
  workspaceId String
  parentId    String?
  title       String
  body        String @default("") @db.Text
  position    Int    @default(0)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent    KnowledgeArticle? @relation("KnowledgeTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  KnowledgeArticle[] @relation("KnowledgeTree")
  creator   User                  @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([parentId])
}
