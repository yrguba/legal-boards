DATABASE_URL="postgresql://legaluser:yourpassword@localhost:5432/legalboards?schema=public"
JWT_SECRET="your-random-secret-key-here-change-this"
PORT=5004
# Базовый URL для Swagger «Try it out» (без /api). Если не задан — http://localhost:${PORT}
# SWAGGER_SERVER_URL=http://localhost:5004
# SWAGGER_SERVER_URL=https://api.example.com
NODE_ENV=development
UPLOAD_DIR=./uploads

# Самостоятельная регистрация и восстановление пароля (true / false; нужен Resend)
REGISTRATION_ENABLED=false

# Подтверждение email через Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM="Legal Boards <onboarding@resend.dev>"

# true | 1 | yes — email со ссылкой при добавлении сотрудника / приглашении в пространство.
# false — временный пароль показывается администратору в модалке (без письма).
WORKSPACE_INVITE_EMAIL=false

# URL фронтенда для ссылок в письмах
FRONTEND_URL=http://localhost:5173


# Вкладка «Клиенты LEXPRO» в Legal Boards (true / false; по умолчанию true)
LEXPRO_CLIENTS_ENABLED=true

# Вкладки в боковом меню (true / false; по умолчанию true)
DOCUMENTS_ENABLED=true
KNOWLEDGE_ENABLED=true
CHAT_ENABLED=true
CALENDAR_ENABLED=true

# Push-уведомления (staff mobile)
PUSH_ENABLED=false
# Отправка push на мобильные устройства (iOS/Android); требует PUSH_ENABLED=true
PUSH_MOBILE_ENABLED=true
PUSH_ANDROID_ENABLED=true
PUSH_IOS_ENABLED=true
# Firebase Cloud Messaging (Android)
FIREBASE_SERVICE_ACCOUNT_PATH=
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Apple Push Notification service (iOS)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
# Относительный путь — от папки backend/ (не от cwd pm2)
APNS_KEY_PATH=AuthKey_XXXXXXXXXX.p8
APNS_PRODUCTION=false
# Логирование push в stdout (true / false; по умолчанию true)
PUSH_LOG=true


